type Query {
    field(arg: A): String
}

input A {
    b: B!
}

# This is an example of a SCC of size 3 containing 2 cycles (A <-> B) and (B <-> C). Only (B <-> C) is reported
# Input object `B` references itself through an unbreakable chain of input fields and cannot be constructed: B.c --> C.b --> B
input B {
    a: A!
    c: C!
}

input C {
    b: B!
    c: C!
}